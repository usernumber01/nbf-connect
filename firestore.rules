// NBF Connect — Firestore Security Rules
// Last updated: June 2026
// Default: DENY ALL. Only explicitly listed paths are accessible.
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // DEFAULT: deny everything unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // Shurveers — authenticated user can only read/write their own doc
    match /shurveers/{userId} {
      allow read, update, delete: if request.auth != null 
        && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Partner signups — authenticated user reads only their own doc
    match /partnerSignups/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null 
        && request.auth.uid == resource.data.uid;
    }

    // Discussions (schedule-discussion.html submissions)
    match /discussions/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null 
        && request.auth.uid == resource.data.uid;
    }

    // Opportunities — any authenticated user can read
    // only admin can write (admin check via custom claim)
    match /opportunities/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.token.admin == true;
    }

    // Public opportunities — readable by anyone (unauthenticated)
    // for the public opportunities listing page
    match /publicOpportunities/{docId} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.token.admin == true;
    }
  }
}
