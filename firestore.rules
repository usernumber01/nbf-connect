// NBF Connect — Firestore Security Rules
// Last updated: June 2026
// Default: DENY ALL. Only explicitly listed paths are accessible.
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // DEFAULT: deny everything unless explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }

    // Users — authenticated user can only read/write their own doc, admins can read all
    match /users/{userId} {
      allow read, update, delete: if request.auth != null 
        && (request.auth.uid == userId || request.auth.token.admin == true);
      allow create: if request.auth != null;
    }

    // Partner signups — allow unauthenticated creation, strict read/update (plus admin)
    match /partnerSignups/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null 
        && (request.auth.uid == resource.data.uid || request.auth.token.admin == true);
    }

    // Partners — allow unauthenticated creation, strict read/update (plus admin)
    match /partners/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null 
        && (request.auth.uid == resource.data.uid || request.auth.token.admin == true);
    }

    // Discussions (schedule-discussion.html submissions) — strictly enforce creation by authenticated owner
    match /discussions/{docId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null 
        && request.auth.uid == resource.data.uid;
    }

    // Applications — strictly enforce creation by authenticated owner
    match /applications/{docId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null 
        && request.auth.uid == resource.data.uid;
    }

    // Opportunities — any authenticated user can read
    // only admin can write (admin check via custom claim)
    match /opportunities/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.token.admin == true;
    }

    // Public opportunities — readable by anyone (unauthenticated)
    // for the public opportunities listing page
    match /publicOpportunities/{docId} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.token.admin == true;
    }
  }
}
